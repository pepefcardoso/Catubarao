generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Member {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String?
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  
  cpf           String?   @unique
  phone         String?
  birthDate     DateTime?
  referralCode  String?
  isActive      Boolean   @default(true)
  marketingConsent Boolean @default(false)
  whatsappOptIn    Boolean @default(false)
  address       Json?

  referredById  String?
  referredBy    Member?   @relation("MemberReferrals", fields: [referredById], references: [id])
  referrals     Member[]  @relation("MemberReferrals")

  sessions           Session[]
  accounts           Account[]
  subscriptions      Subscription[]
  gamificationEvents GamificationEvent[]
  membershipCards    MembershipCard[]
  pollVotes          PollVote[]

  @@unique([email])
  @@map("members")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  member         Member   @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  member                Member    @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model Jwks {
  id         String    @id
  publicKey  String
  privateKey String
  createdAt  DateTime
  expiresAt  DateTime?

  @@map("jwks")
}

enum SubscriptionInterval {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  PENDING
  SUSPENDED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  PIX
}

enum GamificationEventType {
  CHECKIN
  REFERRAL
  ANNIVERSARY
  STREAK_6M
  STREAK_12M
}

enum PollStatus {
  DRAFT
  OPEN
  CLOSED
}

model MembershipPlan {
  id          String               @id @default(uuid())
  name        String
  price       Decimal
  interval    SubscriptionInterval
  benefits    String[]
  isCorporate Boolean              @default(false)
  maxCards    Int?
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())

  subscriptions Subscription[]

  @@map("membership_plans")
}

model Subscription {
  id                    String             @id @default(uuid())
  memberId              String
  planId                String
  status                SubscriptionStatus
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  gatewaySubscriptionId String?
  cancelledAt           DateTime?
  createdAt             DateTime           @default(now())

  member          Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  plan            MembershipPlan   @relation(fields: [planId], references: [id])
  payments        Payment[]
  membershipCards MembershipCard[]

  @@index([memberId, status])
  @@map("subscriptions")
}

model Payment {
  id               String        @id @default(uuid())
  subscriptionId   String?
  orderId          String?
  gatewayPaymentId String?
  amount           Decimal
  status           PaymentStatus
  method           PaymentMethod
  paidAt           DateTime?
  createdAt        DateTime      @default(now())

  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@map("payments")
}

model MembershipCard {
  id             String   @id @default(uuid())
  memberId       String
  subscriptionId String
  qrToken        String   @unique
  validUntil     DateTime
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([memberId, isActive])
  @@map("membership_cards")
}

model GamificationEvent {
  id        String                @id @default(uuid())
  memberId  String
  type      GamificationEventType
  points    Int
  metadata  Json?
  createdAt DateTime              @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("gamification_events")
}

model Poll {
  id                String     @id @default(uuid())
  title             String
  description       String
  options           Json
  opensAt           DateTime
  closesAt          DateTime
  quorumMinimum     Int
  requiresSeniority Boolean    @default(false)
  status            PollStatus @default(DRAFT)
  createdAt         DateTime   @default(now())

  votes PollVote[]

  @@map("polls")
}

model PollVote {
  id        String   @id @default(uuid())
  pollId    String
  memberId  String
  optionId  String
  createdAt DateTime @default(now())

  poll   Poll   @relation(fields: [pollId], references: [id])
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([pollId, memberId])
  @@map("poll_votes")
}
