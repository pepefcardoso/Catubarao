generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Member {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String?
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?

  cpf                     String?   @unique
  phone                   String?
  birthDate               DateTime?
  referralCode            String?   @unique
  isActive                Boolean   @default(true)
  marketingConsent        Boolean   @default(false)
  whatsappOptIn           Boolean   @default(false)
  whatsappOptInDismissedAt DateTime?
  address                 Json?
  showOnMonument          Boolean   @default(false)
  showOnLeaderboard       Boolean   @default(false)
  adimplenciaStreakMonths Int       @default(0)
  lastAdimplenciaResetAt  DateTime?
  adminNotes              String?

  referredById String?
  referredBy   Member?  @relation("MemberReferrals", fields: [referredById], references: [id])
  referrals    Member[] @relation("MemberReferrals")

  isAnonymized Boolean  @default(false)

  sessions            Session[]
  accounts            Account[]
  auditLogs           AuditLog[]
  subscriptions       Subscription[]
  gamificationEvents  GamificationEvent[]
  membershipCards     MembershipCard[]
  pollVotes           PollVote[]
  transparencyPosts   TransparencyPost[]
  debtSnapshots       DebtSnapshot[]
  managedDeals        SponsorshipDeal[]   @relation("DealOwner")
  managedDeliverables Deliverable[]       @relation("DeliverableOwner")
  deliveryProofs      DeliveryProof[]     @relation("ProofAuthor")
  orders              Order[]

  consentLogs         ConsentLog[]

  @@unique([email])
  @@map("members")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  member         Member   @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  member                Member    @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model Jwks {
  id         String    @id
  publicKey  String
  privateKey String
  createdAt  DateTime
  expiresAt  DateTime?

  @@map("jwks")
}

enum SubscriptionInterval {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  PENDING
  SUSPENDED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  PIX
}

enum GamificationEventType {
  CHECKIN
  REFERRAL
  ANNIVERSARY
  STREAK_6M
  STREAK_12M
  STREAK_24M
  STREAK_36M
  STREAK_60M
}

enum PollStatus {
  DRAFT
  OPEN
  CLOSED
}

model MembershipPlan {
  id          String               @id @default(uuid())
  name        String
  price       Decimal
  interval    SubscriptionInterval
  benefits    String[]
  isCorporate Boolean              @default(false)
  maxCards    Int?
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())

  subscriptions Subscription[]

  @@map("membership_plans")
}

model Subscription {
  id                    String             @id @default(uuid())
  memberId              String
  planId                String
  status                SubscriptionStatus
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  gatewaySubscriptionId String?
  cancelledAt           DateTime?
  createdAt             DateTime           @default(now())

  member          Member                     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  plan            MembershipPlan             @relation(fields: [planId], references: [id])
  payments        Payment[]
  membershipCards MembershipCard[]
  notifications   SubscriptionNotification[]

  @@index([memberId, status])
  @@map("subscriptions")
}

model Payment {
  id               String        @id @default(uuid())
  subscriptionId   String?
  orderId          String?
  gatewayPaymentId String?       @unique
  amount           Decimal
  status           PaymentStatus
  method           PaymentMethod
  paidAt           DateTime?
  createdAt        DateTime      @default(now())

  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  order        Order?        @relation(fields: [orderId], references: [id])

  @@index([subscriptionId])
  @@index([orderId])
  @@map("payments")
}

model MembershipCard {
  id             String   @id @default(uuid())
  memberId       String
  subscriptionId String
  qrToken        String   @unique
  validUntil     DateTime
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([memberId, isActive])
  @@map("membership_cards")
}

model GamificationEvent {
  id             String                @id @default(uuid())
  memberId       String
  type           GamificationEventType
  points         Int
  metadata       Json?
  idempotencyKey String?               @unique
  createdAt      DateTime              @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("gamification_events")
}

model GamificationRule {
  id        String                @id @default(uuid())
  type      GamificationEventType @unique
  points    Int
  isActive  Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@map("gamification_rules")
}

model Poll {
  id                String     @id @default(uuid())
  title             String
  description       String
  options           Json
  opensAt           DateTime
  closesAt          DateTime
  quorumMinimum     Int
  requiresSeniority Boolean    @default(false)
  status            PollStatus @default(DRAFT)
  createdAt         DateTime   @default(now())

  votes PollVote[]

  @@map("polls")
}

model PollVote {
  id        String   @id @default(uuid())
  pollId    String
  memberId  String
  optionId  String
  createdAt DateTime @default(now())

  poll   Poll   @relation(fields: [pollId], references: [id])
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([pollId, memberId])
  @@map("poll_votes")
}

model SubscriptionNotification {
  id             String   @id @default(uuid())
  subscriptionId String
  type           String
  sentAt         DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, type])
  @@map("subscription_notifications")
}

model DashboardGoal {
  id        String   @id @default(uuid())
  label     String
  target    Int
  metric    String
  createdAt DateTime @default(now())

  @@map("dashboard_goals")
}

model MatchEvent {
  id          String   @id @default(uuid())
  date        DateTime
  opponent    String
  competition String
  createdAt   DateTime @default(now())

  deliveryProofs    DeliveryProof[]
  pendingDeliveries PendingDelivery[]

  @@map("match_events")
}

enum TransparencyCategory {
  BALANCO_MENSAL
  STATUS_DIVIDAS
  ATA_ASSEMBLEIA
  COMPOSICAO_SOCIETARIA
  DOCUMENTO_SAF
  OUTRO
}

enum DebtStatus {
  EM_NEGOCIACAO
  EM_DIA
  ATRASADO
  QUITADO
}

model TransparencyPost {
  id             String               @id @default(uuid())
  title          String
  category       TransparencyCategory
  referenceMonth Int?
  referenceYear  Int?
  body           String
  attachmentUrl  String?
  publishedAt    DateTime
  scheduledFor   DateTime?
  version        Int                  @default(1)
  supersededById String?
  supersededBy   TransparencyPost?    @relation("PostVersions", fields: [supersededById], references: [id])
  versions       TransparencyPost[]   @relation("PostVersions")
  isArchived     Boolean              @default(false)
  createdBy      String
  author         Member               @relation(fields: [createdBy], references: [id])
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([category, publishedAt])
  @@map("transparency_posts")
}

model DebtRecord {
  id               String     @id @default(uuid())
  slug             String     @unique
  creditorName     String
  creditorGroup    String?
  originalAmount   Decimal
  negotiatedAmount Decimal?
  paidAmount       Decimal    @default(0)
  status           DebtStatus
  publicNote       String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@map("debt_records")
}

model DebtSnapshot {
  id              String   @id @default(uuid())
  totalOriginal   Decimal
  totalNegotiated Decimal
  totalPaid       Decimal
  totalRemaining  Decimal
  snapshotDate    DateTime @db.Date
  createdBy       String?
  author          Member?  @relation(fields: [createdBy], references: [id])
  createdAt       DateTime @default(now())

  @@map("debt_snapshots")
}

enum BadgeType {
  ANNOUNCEMENT
  BADGE
}

model AnnouncementBanner {
  id          String    @id @default(uuid())
  type        BadgeType @default(ANNOUNCEMENT)
  text        String
  color       String    @default("brand-primary")
  milestone   Int?
  logoUrl     String?
  description String?
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("announcement_banners")
}

enum PartnerStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  CANCELLED
}

enum DealType {
  FINANCEIRO
  PERMUTA
  MISTO
}

enum DealStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum DeliverableFrequency {
  UNICO
  POR_JOGO
  MENSAL
}

enum EvidenceType {
  FOTO
  PRINT_POST
  LINK
  NOTA
}

model Partner {
  id           String        @id @default(uuid())
  legalName    String
  tradeName    String
  cnpj         String?
  segment      String
  status       PartnerStatus
  contactName  String
  contactEmail String
  contactPhone String
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  deals SponsorshipDeal[]

  @@map("partners")
}

model SponsorshipDeal {
  id             String     @id @default(uuid())
  partnerId      String
  type           DealType
  financialValue Decimal?
  startDate      DateTime   @db.Date
  endDate        DateTime   @db.Date
  status         DealStatus
  ownerId        String
  notes              String?
  cancellationReason String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  partner      Partner       @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  owner        Member        @relation("DealOwner", fields: [ownerId], references: [id])
  deliverables Deliverable[]
  alerts       DealAlert[]   @relation("DealAlerts")

  @@index([endDate])
  @@map("sponsorship_deals")
}

model DealAlert {
  id        String   @id @default(uuid())
  dealId    String
  type      String
  sentAt    DateTime @default(now())

  deal      SponsorshipDeal @relation("DealAlerts", fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, type])
  @@map("deal_alerts")
}

model Deliverable {
  id          String               @id @default(uuid())
  dealId      String
  description String
  frequency   DeliverableFrequency
  ownerId     String

  deal              SponsorshipDeal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  owner             Member            @relation("DeliverableOwner", fields: [ownerId], references: [id])
  proofs            DeliveryProof[]
  pendingDeliveries PendingDelivery[]

  @@map("deliverables")
}

model DeliveryProof {
  id            String       @id @default(uuid())
  deliverableId String
  matchEventId  String?
  deliveredAt   DateTime     @db.Date
  evidenceType  EvidenceType
  fileUrl       String?
  linkUrl       String?
  notes         String?
  createdBy     String
  createdAt     DateTime     @default(now())

  deliverable Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  matchEvent  MatchEvent? @relation(fields: [matchEventId], references: [id])
  author      Member      @relation("ProofAuthor", fields: [createdBy], references: [id])

  @@map("delivery_proofs")
}

model PendingDelivery {
  id            String   @id @default(uuid())
  deliverableId String
  matchEventId  String?
  month         Int?
  year          Int?
  isFulfilled   Boolean  @default(false)
  createdAt     DateTime @default(now())

  deliverable Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  matchEvent  MatchEvent? @relation(fields: [matchEventId], references: [id], onDelete: Cascade)

  @@map("pending_deliveries")
}

enum StockType {
  SOB_DEMANDA
  ESTOQUE_FIXO
}

enum OrderStatus {
  AGUARDANDO_PAGAMENTO
  PAGO
  EM_PRODUCAO
  ENVIADO
  ENTREGUE
  CANCELADO
}

model Product {
  id                  String           @id @default(uuid())
  name                String
  description         String
  category            String
  images              String[]
  basePrice           Decimal
  stockType           StockType
  membersOnly         Boolean          @default(false)
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  variants            ProductVariant[]
  orderItems          OrderItem[]

  @@index([isActive, membersOnly])
  @@map("products")
}

model ProductVariant {
  id              String      @id @default(uuid())
  productId       String
  sku             String      @unique
  size            String?
  color           String?
  priceAdjustment Decimal     @default(0)
  stockQuantity       Int?
  stockAlertThreshold Int?
  initialStockQuantity Int?

  product         Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  stockNotifications StockNotification[]

  @@map("product_variants")
}

model Order {
  id              String      @id @default(uuid())
  customerId      String?
  guestEmail      String?
  guestCpf        String?
  shippingAddress Json
  status          OrderStatus @default(AGUARDANDO_PAGAMENTO)
  trackingCode    String?
  total           Decimal
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  customer        Member?     @relation(fields: [customerId], references: [id])
  items           OrderItem[]
  payments        Payment[]

  @@map("orders")
}

model OrderItem {
  id         String          @id @default(uuid())
  orderId    String
  productId  String
  variantId  String?
  quantity   Int
  unitPrice  Decimal

  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id])
  variant    ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  memberId    String?
  performedBy String?
  metadata    Json?
  createdAt   DateTime @default(now())

  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([memberId])
  @@index([action])
  @@map("audit_logs")
}

model ConsentLog {
  id        String   @id @default(uuid())
  memberId  String?
  ipAddress String?
  userAgent String?
  choices   Json
  createdAt DateTime @default(now())

  member    Member?  @relation(fields: [memberId], references: [id])

  @@map("consent_logs")
}

model StockNotification {
  id        String   @id @default(uuid())
  email     String
  variantId String
  createdAt DateTime @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@map("stock_notifications")
}

model Waitlist {
  id        String   @id @default(uuid())
  email     String   @unique
  source    String
  createdAt DateTime @default(now())

  @@map("waitlist")
}
