{
  "name": "@repo/schemas",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./member": "./src/member.ts",
    "./gamification": "./src/gamification.ts",
    "./stats": "./src/stats.ts",
    "./webhooks": "./src/webhooks.ts",
    "./events": "./src/events.ts",
    "./partner": "./src/partner.ts",
    "./transparency": "./src/transparency.ts",
    "./consent": "./src/consent.ts",
