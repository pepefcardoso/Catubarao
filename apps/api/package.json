{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "email:preview": "email dev --dir src/emails --port 3002",
    "build": "tsc && (if [ -n \"$SENTRY_AUTH_TOKEN\" ]; then pnpx @sentry/cli sourcemaps inject dist && pnpx @sentry/cli sourcemaps upload dist; fi)",
    "start": "node dist/server.js",
    "lint": "echo 'api lint'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@bull-board/api": "^8.0.1",
    "@bull-board/fastify": "^8.0.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@react-email/components": "^1.0.12",
    "@repo/db": "workspace:*",
    "@repo/schemas": "workspace:*",
    "@sentry/node": "^10.59.0",
    "@sentry/profiling-node": "^10.59.0",
    "better-auth": "^1.6.20",
    "bullmq": "^5.79.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.11.1",
    "jose": "^5.9.6",
    "mercadopago": "^3.1.0",
    "pino": "^10.3.1",
    "resend": "^6.14.0",
    "zod": "^4.4.3",
    "@react-pdf/renderer": "^3.4.4",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@react-email/ui": "^6.6.3",
    "@repo/config": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^7.2.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  }
}
