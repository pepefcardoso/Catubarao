# Database
DATABASE_URL="postgresql://tubarao:password@localhost:6432/tubarao"
DIRECT_URL="postgresql://tubarao:password@localhost:5432/tubarao"
# DIRECT_URL is used by Prisma migrate (bypasses pgbouncer — required)

# Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"

# Better Auth
BETTER_AUTH_SECRET="dummy-secret-value-32-chars-long"           # 32+ char random string
BETTER_AUTH_URL="https://api.tubarao.fc"

# Mercado Pago
MP_ACCESS_TOKEN="dummy"              # production access token
MP_WEBHOOK_SECRET="dummy"            # for signature verification
MP_PUBLIC_KEY="dummy"                # frontend (non-secret)

# Cloudflare R2
R2_ENDPOINT="https://dummy.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="dummy"
R2_SECRET_ACCESS_KEY="dummy"
R2_BUCKET="tubarao-assets"
R2_PUBLIC_URL="https://assets.tubarao.fc"  # public CDN URL

# QR / JWT signing (ES256 key pair)
QR_PRIVATE_KEY="dummy"               # PKCS8 PEM — api only, never exposed to frontend
QR_PUBLIC_KEY="dummy"                # SPKI PEM — safe to embed in validator PWA

# Resend
RESEND_API_KEY="dummy"
RESEND_FROM="noreply@tubarao.fc"


# Sentry
SENTRY_DSN="http://dummy@sentry.io/1"                   # same value for web and api in MVP
SENTRY_ENVIRONMENT="development"
SENTRY_AUTH_TOKEN=""            # required for source map uploads

# App URLs
NEXT_PUBLIC_APP_URL="https://tubarao.fc"
NEXT_PUBLIC_API_URL="https://api.tubarao.fc"
NEXT_PUBLIC_MP_PUBLIC_KEY=""    # Mercado Pago public key for frontend SDK
NEXT_PUBLIC_QR_PUBLIC_KEY=""    # SPKI PEM for offline frontend validator

# WhatsApp
WHATSAPP_SUPPORT_NUMBER="5548999990000"
